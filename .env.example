# Copy this file to .env and fill in real values.

# Anthropic / Claude — from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# claude-sonnet-5 = best default (quality/cost balance).
# claude-haiku-4-5-20251001 = cheaper/faster if you're running high message volume.
CLAUDE_MODEL=claude-sonnet-5

# WhatsApp Cloud API (Meta) — from developers.facebook.com, WhatsApp > API Setup
WHATSAPP_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=choose-any-random-string
WHATSAPP_API_VERSION=v20.0

# Protects the /businesses admin endpoints — choose a long random string
ADMIN_API_KEY=choose-a-strong-random-key

# Database — SQLite is fine for MVP/demo. Swap to a Postgres URL for production,
# e.g. postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./receptionist.db
